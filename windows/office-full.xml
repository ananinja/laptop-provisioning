<!--
  Full Microsoft 365 suite (extra option - use only when needed).
  Installs everything: Word, Excel, PowerPoint, Outlook, OneNote, Access,
  Publisher, OneDrive, etc. Teams is still excluded because it's installed
  separately as its own app.

  Triggered by:  install.ps1 -FullOffice   (or double-click install-full.cmd)
-->
<Configuration>
  <Add OfficeClientEdition="64" Channel="Current">
    <Product ID="O365ProPlusRetail">
      <Language ID="MatchOS" />
      <ExcludeApp ID="Teams" />
    </Product>
  </Add>
  <Display Level="None" AcceptEULA="TRUE" />
  <Property Name="FORCEAPPSHUTDOWN" Value="TRUE" />
</Configuration>
